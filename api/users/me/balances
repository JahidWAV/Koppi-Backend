// api/users/me/balances.ts
import type { VercelRequest, VercelResponse } from '@vercel/node';

const PRIVY_APP_ID = process.env.PRIVY_APP_ID!;
const PRIVY_APP_SECRET = process.env.PRIVY_APP_SECRET!;
const PRIVY_BASE_URL = 'https://api.privy.io';
const KOPPI_BASE_URL = 'https://api.koppi.app';

type WalletDescriptor = {
  id?: string;
  address?: string;
  chain_type?: string;
  wallet_client_type?: string;
  connector_type?: string;
};

type WalletBalanceEntry = {
  chain: string;
  asset: string;
  raw_value: string;
  raw_value_decimals: number;
  display_values: Record<string, string>;
};

type WalletBalanceResponse = {
  balances: WalletBalanceEntry[];
};

type BitcoinWalletResponse = {
  address: string;
  walletId?: string;
  publicKey?: string;
  chainType?: string;
};

function basicAuthHeader(appId: string, appSecret: string) {
  return `Basic ${Buffer.from(`${appId}:${appSecret}`).toString('base64')}`;
}

async function getAuthenticatedUser(token: string) {
  const response = await fetch(`${KOPPI_BASE_URL}/api/users/me/debug-token`, {
    headers: {
      Authorization: `Bearer ${token}`,
    },
  });

  if (!response.ok) return null;
  return response.json();
}

async function getPrivyUserWallets(privyUserId: string) {
  const response = await fetch(`${PRIVY_BASE_URL}/v1/users/${privyUserId}/wallets`, {
    method: 'GET',
    headers: {
      Authorization: basicAuthHeader(PRIVY_APP_ID, PRIVY_APP_SECRET),
      'privy-app-id': PRIVY_APP_ID,
    },
  });

  if (!response.ok) {
    throw new Error(`Failed to fetch Privy wallets: ${response.status}`);
  }

  const data = await response.json();
  return (data.wallets ?? []) as WalletDescriptor[];
}

async function fetchWalletBalance(
  walletId: string,
  asset: string | string[],
  chain: string | string[]
) {
  const url = new URL(`${PRIVY_BASE_URL}/v1/wallets/${walletId}/balance`);

  if (Array.isArray(asset)) {
    asset.forEach((a) => url.searchParams.append('asset', a));
  } else {
    url.searchParams.set('asset', asset);
  }

  if (Array.isArray(chain)) {
    chain.forEach((c) => url.searchParams.append('chain', c));
  } else {
    url.searchParams.set('chain', chain);
  }

  url.searchParams.set('include_currency', 'usd');

  const response = await fetch(url.toString(), {
    method: 'GET',
    headers: {
      Authorization: basicAuthHeader(PRIVY_APP_ID, PRIVY_APP_SECRET),
      'privy-app-id': PRIVY_APP_ID,
    },
  });

  if (!response.ok) {
    throw new Error(`Failed wallet balance fetch: ${response.status}`);
  }

  return response.json() as Promise<WalletBalanceResponse>;
}

async function fetchBitcoinBalanceFromKoppi(token: string) {
  const response = await fetch(`${KOPPI_BASE_URL}/api/users/me/wallets/bitcoin/balance`, {
    method: 'GET',
    headers: {
      Authorization: `Bearer ${token}`,
      Accept: 'application/json',
    },
  });

  if (!response.ok) {
    return null;
  }

  return response.json();
}

function normalizeEntry(
  balances: WalletBalanceEntry[],
  chain: string,
  symbol: string,
  fallbackSymbol?: string
) {
  const entry = balances.find((b) => b.chain === chain);

  return {
    symbol: fallbackSymbol ?? symbol.toUpperCase(),
    amount: entry?.display_values?.[symbol] ?? '0',
    fiatValue: entry?.display_values?.usd ?? '0',
    chain,
  };
}

export default async function handler(req: VercelRequest, res: VercelResponse) {
  if (req.method !== 'GET') {
    return res.status(405).json({ error: 'Method not allowed' });
  }

  try {
    const authHeader = req.headers.authorization;
    const token = authHeader?.startsWith('Bearer ') ? authHeader.slice(7) : null;

    if (!token) {
      return res.status(401).json({ error: 'Missing bearer token' });
    }

    const user = await getAuthenticatedUser(token);

    if (!user) {
      return res.status(401).json({ error: 'Unauthorized' });
    }

    const privyUserId =
      user?.privyUserId ||
      user?.privy_user_id ||
      user?.userId ||
      user?.id;

    if (!privyUserId) {
      return res.status(400).json({ error: 'Missing Privy user id' });
    }

    const wallets = await getPrivyUserWallets(privyUserId);

    const evmWallet =
      wallets.find((w) => w.chain_type === 'ethereum') ||
      wallets.find((w) => w.wallet_client_type === 'privy');

    const solanaWallet =
      wallets.find((w) => w.chain_type === 'solana');

    if (!evmWallet?.id) {
      return res.status(400).json({ error: 'No EVM wallet found' });
    }

    const [evmBalances, solBalances, bitcoinBalance] = await Promise.all([
      fetchWalletBalance(
        evmWallet.id,
        ['eth', 'pol'],
        ['ethereum', 'base', 'arbitrum', 'polygon']
      ),
      solanaWallet?.id
        ? fetchWalletBalance(solanaWallet.id, 'sol', 'solana')
        : Promise.resolve({ balances: [] }),
      fetchBitcoinBalanceFromKoppi(token),
    ]);

    const ethereum = normalizeEntry(evmBalances.balances, 'ethereum', 'eth', 'ETH');
    const base = normalizeEntry(evmBalances.balances, 'base', 'eth', 'ETH');
    const arbitrum = normalizeEntry(evmBalances.balances, 'arbitrum', 'eth', 'ETH');
    const polygon = normalizeEntry(evmBalances.balances, 'polygon', 'pol', 'POL');
    const solana = normalizeEntry(solBalances.balances, 'solana', 'sol', 'SOL');

    const bitcoin = bitcoinBalance
      ? {
          symbol: bitcoinBalance.symbol ?? 'BTC',
          amount: bitcoinBalance.amount ?? '0',
          fiatValue: bitcoinBalance.fiatValue ?? '0',
          chain: 'bitcoin',
        }
      : {
          symbol: 'BTC',
          amount: '0',
          fiatValue: '0',
          chain: 'bitcoin',
        };

    const totalUsd = [
      ethereum.fiatValue,
      base.fiatValue,
      arbitrum.fiatValue,
      polygon.fiatValue,
      solana.fiatValue,
      bitcoin.fiatValue,
    ]
      .map((v) => Number(v ?? '0'))
      .filter((v) => Number.isFinite(v))
      .reduce((sum, v) => sum + v, 0)
      .toFixed(2);

    return res.status(200).json({
      balances: {
        ethereum,
        base,
        arbitrum,
        polygon,
        solana,
        bitcoin,
      },
      totalUsd,
      wallets: {
        evm: evmWallet.address ?? null,
        solana: solanaWallet?.address ?? null,
      },
    });
  } catch (error) {
    console.error('GET /api/users/me/balances error', error);
    return res.status(500).json({ error: 'Failed to fetch balances' });
  }
}
